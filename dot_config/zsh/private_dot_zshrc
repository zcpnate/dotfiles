setopt globdots

export ZSH="$ZDOTDIR/.oh-my-zsh"
export STARSHIP_CONFIG="$XDG_CONFIG_HOME/starship/starship.toml"

# Prompt handled by starship (see `starship init zsh` at end); no OMZ theme.
ZSH_THEME=""

zstyle ':omz:update' mode auto

HYPHEN_INSENSITIVE="true"              # treat _ and - as interchangeable in completion
COMPLETION_WAITING_DOTS="true"         # show dots while slow completions (kubectl/aws) load

# Completion / fzf-tab tuning
zstyle ':completion:*:git-checkout:*' sort false                             # don't sort git checkout candidates
zstyle ':completion:*:descriptions' format '[%d]'                            # group support (no escape seqs; fzf-tab ignores them)
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}                        # colorize filenames
zstyle ':completion:*' menu no                                               # let fzf-tab capture the prefix
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls -1 --color=always $realpath'  # preview dir on cd
zstyle ':fzf-tab:*' switch-group '<' '>'                                     # switch groups with < / >

DISABLE_UNTRACKED_FILES_DIRTY="true"   # faster VCS status in large repos
ZSH_CUSTOM=$ZDOTDIR/custom

plugins=(
aws
brew
gcloud
git
gh
fzf
fast-syntax-highlighting
fzf-tab
zsh-autosuggestions
zsh-lsd
zsh-bat
mise
kubectl
helm
docker
orb
1password
you-should-use
ohmyzsh-full-autoupdate
zoxide
colored-man-pages
command-not-found
extract
sudo
macos
fancy-ctrl-z
)

# History — re-assert here: macOS /etc/zshrc resets HISTFILE/SIZE for interactive
# shells AFTER .zshenv, so these must override it (not redundant with .zshenv).
export HISTFILE="$XDG_STATE_HOME/zsh/history"
export HISTSIZE=50000          # commands kept in memory
export SAVEHIST=50000          # commands saved to file
setopt HIST_IGNORE_DUPS        # drop duplicate commands
setopt HIST_IGNORE_SPACE       # drop commands starting with a space
setopt HIST_VERIFY             # confirm history-expansion before running
setopt SHARE_HISTORY           # share history across sessions
setopt APPEND_HISTORY          # append, don't overwrite
setopt INC_APPEND_HISTORY      # write immediately, not on exit

export EDITOR="code"

# Personal aliases live in $ZDOTDIR/aliases.zsh (sourced after oh-my-zsh below).
export PATH="$HOME/.git-tools:$PATH"

test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

# fzf
export FZF_DEFAULT_COMMAND='fd --type f'
export FZF_DEFAULT_OPTS="--ansi --height=40% --preview-window 'right:60%:wrap'"
export FZF_CTRL_T_OPTS="
  --preview 'bat --color=always --style=numbers --line-range=:500 {}'
  --bind 'ctrl-/:change-preview-window(down|hidden|)'"
# CTRL-/ toggles preview; CTRL-Y copies the command to the clipboard
export FZF_CTRL_R_OPTS="
  --preview 'echo {}' --preview-window up:3:hidden:wrap
  --bind 'ctrl-/:toggle-preview'
  --bind 'ctrl-y:execute-silent(echo -n {2..} | pbcopy)+abort'
  --color header:italic
  --header 'Press CTRL-Y to copy command into clipboard'"
export FZF_ALT_C_OPTS="
  --preview 'tree -C {}'"

export PATH=~/.local/bin:$PATH
export PATH="/opt/homebrew/sbin:$PATH"
export PATH="$BUN_INSTALL/bin:$PATH"

source $ZSH/oh-my-zsh.sh
source $ZDOTDIR/aliases.zsh

unalias gsd 2>/dev/null

eval "$(starship init zsh)"

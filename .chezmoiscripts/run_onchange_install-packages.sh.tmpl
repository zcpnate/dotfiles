#!/bin/bash
# Provision Homebrew packages. Re-runs whenever the tracked package list changes:
# packages.yaml hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}

# On first run brew isn't on PATH yet (its shellenv is loaded by new login
# shells, not this script). Locate it for Apple Silicon or Intel and load it.
if ! command -v brew >/dev/null 2>&1; then
    for brew_path in /opt/homebrew/bin/brew /usr/local/bin/brew; do
        if [ -x "$brew_path" ]; then
            eval "$("$brew_path" shellenv)"
            break
        fi
    done
fi

if ! command -v brew >/dev/null 2>&1; then
    echo "brew not found on PATH; cannot install packages." >&2
    exit 1
fi

# NOTE: `brew bundle` is fail-fast — one bad entry (e.g. the 1password cask's
# checksum mismatch, or a cask needing manual approval) aborts the whole run and
# skips every package after it. Install per entry instead so a single failure
# can't block the other ~126 packages. Skip already-installed items (keeps
# re-runs fast and avoids surprise upgrades), collect failures, report them, and
# exit 0 so the rest of the chezmoi apply proceeds.

taps=(
{{ range .packages.brews.tap }}    {{ . | quote }}
{{ end }})
formulae=(
{{ range .packages.brews.formulae }}    {{ . | quote }}
{{ end }})
casks=(
{{ range .packages.brews.casks }}    {{ . | quote }}
{{ end }})

failed=()

# Casks that run privileged (sudo) installers authenticate via Touch ID, enabled
# earlier by run_once_before_enable-touchid-sudo. That works in chezmoi's
# TTY-less context where a password prompt would fail with "unable to read
# password: Input/output error".

for t in "${taps[@]}"; do
    brew tap "$t" || failed+=("tap $t")
done

for f in "${formulae[@]}"; do
    brew list --formula --versions "$f" >/dev/null 2>&1 && continue
    brew install --formula "$f" || failed+=("brew $f")
done

for c in "${casks[@]}"; do
    brew list --cask --versions "$c" >/dev/null 2>&1 && continue
    brew install --cask "$c" || failed+=("cask $c")
done

if [ ${#failed[@]} -gt 0 ]; then
    echo >&2
    echo "⚠️  ${#failed[@]} Homebrew item(s) failed to install:" >&2
    printf '   - %s\n' "${failed[@]}" >&2
    echo "   Retry an individual item, e.g.: brew install --cask 1password" >&2
fi

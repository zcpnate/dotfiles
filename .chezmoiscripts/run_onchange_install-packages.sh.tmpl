#!/bin/bash
set -o pipefail

# On first run brew isn't on PATH yet (its shellenv is loaded by new login
# shells, not this script). Locate it for Apple Silicon or Intel and load it.
if ! command -v brew >/dev/null 2>&1; then
    for brew_path in /opt/homebrew/bin/brew /usr/local/bin/brew; do
        if [ -x "$brew_path" ]; then
            eval "$("$brew_path" shellenv)"
            break
        fi
    done
fi

LOG="${HOME}/.cache/chezmoi-brew-bundle.log"
mkdir -p "$(dirname "$LOG")"

# brew bundle installs everything it can and reports failures at the end. Don't
# let one failed entry (e.g. a cask needing manual approval) abort the rest of
# the chezmoi apply — tee to a log and exit 0 so the after-scripts (shell change,
# mise, tmux) still run. Retry the failures later with: brew bundle install
if ! brew bundle --file=/dev/stdin 2>&1 <<EOF | tee "$LOG"
{{ range .packages.brews.tap -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.brews.formulae -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.brews.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF
then
    echo >&2
    echo "⚠️  Some Homebrew packages failed to install. Retry: brew bundle install" >&2
    echo "   Full log: $LOG" >&2
fi
